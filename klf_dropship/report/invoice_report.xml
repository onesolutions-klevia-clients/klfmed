<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Override the default invoice document template -->
    <template id="report_invoice_document_inherit_klfmed" inherit_id="account.report_invoice_document" priority="99">
        <xpath expr="//div[@class='page']" position="replace">
            <div class="page" style="font-family: Arial, sans-serif; font-size: 10pt;">

                <!-- Header Section -->
                <div class="row mb-4">
                    <!-- Company Info (Left) -->
                    <div class="col-6">
                        <div style="margin-bottom: 10px;">
                            <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)"
                                 style="max-height: 80px;" alt="Company Logo"/>
                        </div>
                        <div style="font-size: 9pt; line-height: 1.4;">
                            <strong t-field="o.company_id.name"/><br/>
                            <span t-field="o.company_id.street"/><br/>
                            <span t-field="o.company_id.zip"/> <span t-field="o.company_id.city"/> - <span t-field="o.company_id.country_id.name"/><br/>
                            <br/>
                            <span t-if="o.company_id.phone">Tel. <span t-field="o.company_id.phone"/><br/></span>
                            <span t-if="o.company_id.company_registry">Registration number: <span t-field="o.company_id.company_registry"/></span>
                        </div>
                    </div>

                    <!-- Customer Info (Right) -->
                    <div class="col-6 text-end">
                        <div style="font-size: 9pt; line-height: 1.4; text-align: right;">
                            <strong t-field="o.partner_id.name"/><br/>
                            <t t-if="o.partner_id.street">
                                <span t-field="o.partner_id.street"/><br/>
                            </t>
                            <t t-if="o.partner_id.street2">
                                <span t-field="o.partner_id.street2"/><br/>
                            </t>
                            <span t-field="o.partner_id.city"/>
                            <t t-if="o.partner_id.zip"> <span t-field="o.partner_id.zip"/></t><br/>
                            <span t-field="o.partner_id.country_id.name"/>
                        </div>
                    </div>
                </div>

                <!-- Document Title -->
                <h2 class="mt-4 mb-4" style="color: #0066a1; font-size: 16pt; font-weight: bold;">
                    COMMERCIAL INVOICE
                </h2>

                <!-- Ship-To Section -->
                <t t-if="o.partner_shipping_id and o.partner_shipping_id != o.partner_id">
                    <div class="row mb-3">
                        <div class="col-6">
                            <div style="background-color: #f5f5f5; padding: 10px; border-radius: 4px;">
                                <strong style="color: #0066a1;">SHIP TO :</strong><br/>
                                <span t-field="o.partner_shipping_id.name"/><br/>
                                <t t-if="o.partner_shipping_id.street">
                                    <span t-field="o.partner_shipping_id.street"/><br/>
                                </t>
                                <t t-if="o.partner_shipping_id.street2">
                                    <span t-field="o.partner_shipping_id.street2"/><br/>
                                </t>
                                <span t-field="o.partner_shipping_id.city"/>
                                <t t-if="o.partner_shipping_id.zip"> <span t-field="o.partner_shipping_id.zip"/></t><br/>
                                <span t-field="o.partner_shipping_id.country_id.name"/>
                            </div>
                        </div>
                    </div>
                </t>

                <!-- Shipment & Trade Information + Invoice Identification -->
                <div class="row mb-4">
                    <!-- Shipment Info (Left) -->
                    <div class="col-6">
                        <table class="table table-sm" style="font-size: 9pt;">
                            <tr t-if="o.x_studio_port_of_loading">
                                <td style="width: 40%; font-weight: bold;">Port of Loading</td>
                                <td t-field="o.x_studio_port_of_loading"/>
                            </tr>
                            <tr t-if="o.x_studio_port_of_destination">
                                <td style="font-weight: bold;">Port of Destination</td>
                                <td t-field="o.x_studio_port_of_destination"/>
                            </tr>
                            <tr t-if="o.invoice_incoterm_id">
                                <td style="font-weight: bold;">Incoterms</td>
                                <td><span t-field="o.invoice_incoterm_id.code"/> <span t-field="o.invoice_incoterm_id.name"/></td>
                            </tr>
                            <tr t-if="o.x_studio_bl_no">
                                <td style="font-weight: bold;">BL No.</td>
                                <td t-field="o.x_studio_bl_no"/>
                            </tr>
                        </table>
                    </div>

                    <!-- Invoice Identification (Right) -->
                    <div class="col-6">
                        <table class="table table-sm" style="font-size: 9pt;">
                            <tr>
                                <td style="width: 40%; font-weight: bold;">Invoice number</td>
                                <td t-field="o.name"/>
                            </tr>
                            <tr>
                                <td style="font-weight: bold;">Invoice date</td>
                                <td t-field="o.invoice_date" t-options='{"format": "MMMM dd, yyyy"}'/>
                            </tr>
                            <tr t-if="o.x_studio_yr_order_no">
                                <td style="font-weight: bold;">Yr/order no.</td>
                                <td t-field="o.x_studio_yr_order_no"/>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Invoice Lines Table -->
                <table class="table table-sm table-bordered" style="font-size: 8pt;">
                    <thead style="background-color: #0066a1; color: white;">
                        <tr>
                            <th style="width: 10%;">Product Code</th>
                            <th style="width: 22%;">Description</th>
                            <th style="width: 10%;">Lot No.</th>
                            <th style="width: 10%;">Expiration Date</th>
                            <th style="width: 8%; text-align: right;">Quantity</th>
                            <th style="width: 12%;">PO no.</th>
                            <th style="width: 12%; text-align: right;">Unit Price <span t-field="o.currency_id.name"/></th>
                            <th style="width: 12%; text-align: right;">Amount <span t-field="o.currency_id.name"/></th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="o.invoice_line_ids.filtered(lambda l: not l.display_type)" t-as="line">
                            <tr>
                                <td>
                                    <span t-if="line.product_id" t-field="line.product_id.default_code"/>
                                </td>
                                <td>
                                    <span t-field="line.name"/>
                                </td>
                                <td>
                                    <span t-if="line.x_studio_lot_number" t-field="line.x_studio_lot_number"/>
                                </td>
                                <td>
                                    <span t-if="line.x_studio_expiration_date" t-field="line.x_studio_expiration_date"/>
                                </td>
                                <td style="text-align: right;">
                                    <span t-field="line.quantity"/>
                                    <span t-if="line.product_uom_id" t-field="line.product_uom_id.name"/>
                                </td>
                                <td>
                                    <span t-if="line.x_studio_po_no_ref" t-field="line.x_studio_po_no_ref"/>
                                </td>
                                <td style="text-align: right;">
                                    <span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                </td>
                                <td style="text-align: right;">
                                    <span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <!-- Totals Section -->
                <div class="row mt-3">
                    <div class="col-8"/>
                    <div class="col-4">
                        <table class="table table-sm" style="font-size: 9pt;">
                            <tr>
                                <td style="font-weight: bold;">Total quantity</td>
                                <td style="text-align: right;">
                                    <t t-set="total_qty" t-value="sum(line.quantity for line in o.invoice_line_ids.filtered(lambda l: not l.display_type))"/>
                                    <span t-esc="'{:,.0f}'.format(total_qty)"/>
                                </td>
                            </tr>
                            <tr style="background-color: #0066a1; color: white; font-weight: bold;">
                                <td>Total amount</td>
                                <td style="text-align: right;">
                                    <span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Payment Terms -->
                <div class="row mt-4" t-if="o.invoice_payment_term_id">
                    <div class="col-12">
                        <p style="font-size: 9pt;">
                            <strong>Terms of payment:</strong>
                            <span t-field="o.invoice_payment_term_id.name" style="text-transform: uppercase;"/>
                        </p>
                    </div>
                </div>

                <!-- Banking Information Footer -->
                <div class="row mt-4" style="border-top: 2px solid #0066a1; padding-top: 15px;">
                    <div class="col-12">
                        <table class="table table-sm table-borderless" style="font-size: 9pt;">
                            <tr>
                                <td style="width: 15%; font-weight: bold;">Beneficiary</td>
                                <td t-field="o.company_id.name"/>
                            </tr>
                            <t t-if="o.partner_bank_id">
                                <tr>
                                    <td style="font-weight: bold;">Bank account</td>
                                    <td><span t-field="o.currency_id.name"/> Bank Account</td>
                                </tr>
                                <tr t-if="o.partner_bank_id.acc_number">
                                    <td style="font-weight: bold;">IBAN</td>
                                    <td t-field="o.partner_bank_id.acc_number"/>
                                </tr>
                                <tr t-if="o.partner_bank_id.bank_id">
                                    <td style="font-weight: bold;">Bank</td>
                                    <td>
                                        <span t-field="o.partner_bank_id.bank_id.name"/>
                                        <t t-if="o.partner_bank_id.bank_id.city">
                                            - <span t-field="o.partner_bank_id.bank_id.city"/>
                                        </t>
                                        <t t-if="o.partner_bank_id.bank_id.country">
                                            - <span t-field="o.partner_bank_id.bank_id.country.name"/>
                                        </t>
                                    </td>
                                </tr>
                                <tr t-if="o.partner_bank_id.bank_id.bic">
                                    <td style="font-weight: bold;">BIC / Swift</td>
                                    <td t-field="o.partner_bank_id.bank_id.bic"/>
                                </tr>
                            </t>
                        </table>
                    </div>
                </div>

            </div>
        </xpath>
    </template>

</odoo>
