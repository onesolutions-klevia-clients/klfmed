<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Custom Paper Format without header/footer space -->
    <record id="paperformat_klfmed_invoice" model="report.paperformat">
        <field name="name">KLFMed Invoice Format</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">12</field>
        <field name="margin_right">12</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <!-- KLFMed Custom Invoice Report Definition -->
    <record id="action_report_klfmed_invoice" model="ir.actions.report">
        <field name="name">KLFMed Commercial Invoice</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">klf_dropship.report_invoice_klfmed</field>
        <field name="report_file">klf_dropship.report_invoice_klfmed</field>
        <field name="print_report_name">'%s-INVOICE-%s-%s' % (object.x_studio_invoice_number or (object.name if object.name and object.name != '/' else 'Draft'), (object.partner_id.name or '').upper(), (object.invoice_date or object.date or time.strftime('%Y-%m-%d')).strftime('%d-%b-%Y').upper())</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="klf_dropship.paperformat_klfmed_invoice"/>
    </record>

    <!-- Main Invoice Template -->
    <template id="report_invoice_klfmed">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="klf_dropship.report_invoice_klfmed_document"/>
            </t>
        </t>
    </template>

    <!-- Invoice Document Template -->
    <template id="report_invoice_klfmed_document">
        <t t-call="web.basic_layout">
            <style>
                * {
                    border: none !important;
                }
                table, td, th {
                    border: none !important;
                    border-collapse: collapse;
                }
                html, body {
                    height: 100%;
                    margin: 0;
                    padding: 0;
                }
                .klfmed-invoice {
                    font-family: Arial, Helvetica, sans-serif;
                    font-size: 10pt;
                    color: #333;
                    padding: 10px 20px;
                }
                .klfmed-invoice .company-info {
                    font-size: 9pt;
                    line-height: 1.6;
                    color: #333;
                }
                .klfmed-invoice .company-name {
                    font-size: 10pt;
                    font-weight: bold;
                    color: #0066a1;
                }
                .klfmed-invoice .customer-info {
                    font-size: 9pt;
                    line-height: 1.6;
                    text-align: right;
                }
                .klfmed-invoice .customer-name {
                    font-size: 10pt;
                    font-weight: bold;
                }
                .klfmed-invoice .document-title {
                    font-size: 14pt;
                    font-weight: bold;
                    margin: 20px 0 15px 0;
                }
                .klfmed-invoice .ship-to-section {
                    font-size: 9pt;
                    line-height: 1.5;
                    margin-bottom: 15px;
                }
                .klfmed-invoice .ship-to-label {
                    font-weight: bold;
                    margin-bottom: 5px;
                }
                .klfmed-invoice .info-section {
                    font-size: 9pt;
                    line-height: 1.8;
                    margin-bottom: 15px;
                }
                .klfmed-invoice .info-section .label {
                    font-weight: bold;
                }
                .klfmed-invoice .lines-table {
                    width: 100%;
                    border-collapse: collapse;
                    font-size: 8.5pt;
                    margin-top: 10px;
                }
                .klfmed-invoice .lines-table th {
                    padding: 8px 6px;
                    text-align: left;
                    font-weight: bold;
                    font-size: 8pt;
                    border-bottom: 1px solid #333 !important;
                    border-top: 1px solid #333 !important;
                }
                .klfmed-invoice .lines-table th.text-right {
                    text-align: right;
                }
                .klfmed-invoice .lines-table td {
                    padding: 8px 6px;
                    vertical-align: top;
                    border-bottom: 1px solid #ccc !important;
                }
                .klfmed-invoice .text-right {
                    text-align: right;
                }
                .klfmed-invoice .total-line {
                    border-top: none !important;
                    border-bottom: 3px double #333 !important;
                }
                .klfmed-invoice .total-line td {
                    padding: 8px 6px;
                    font-weight: bold;
                    font-size: 10pt;
                }
                .klfmed-invoice .payment-section {
                    margin-top: 40px;
                    font-size: 9pt;
                }
                .klfmed-invoice .banking-section {
                    margin-top: 25px;
                    font-size: 9pt;
                }
                .klfmed-invoice .banking-section .label {
                    font-weight: bold;
                    width: 120px;
                    display: inline-block;
                }
                .klfmed-invoice .wire-message {
                    margin-top: 30px;
                    font-size: 8.5pt;
                    line-height: 1.5;
                }
            </style>

            <div class="klfmed-invoice">
                <!-- Header Section -->
                <table style="width: 100%; margin-bottom: 10px;">
                    <tr>
                        <!-- Company Info (Left) -->
                        <td style="width: 55%; vertical-align: top;">
                            <div style="margin-bottom: 10px;">
                                <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)"
                                     style="max-height: 60px;" alt="Company Logo"/>
                            </div>
                            <div class="company-info">
                                <div class="company-name" t-field="o.company_id.name"/>
                                <span t-field="o.company_id.street"/><br/>
                                <span t-field="o.company_id.zip"/> <span t-field="o.company_id.city"/> - <span t-field="o.company_id.country_id.name"/><br/>
                                <br/>
                                <span t-if="o.company_id.phone">Tel. <span t-field="o.company_id.phone"/><br/></span>
                                Registration number: <span t-if="o.company_id.company_registry" t-field="o.company_id.company_registry"/>
                            </div>
                        </td>
                        <!-- Customer Info (Right) -->
                        <td style="width: 45%; vertical-align: top;">
                            <div class="customer-info">
                                <div class="customer-name" t-field="o.partner_id.name"/>
                                <t t-if="o.partner_id.street">
                                    <span t-field="o.partner_id.street"/><br/>
                                </t>
                                <t t-if="o.partner_id.street2">
                                    <span t-field="o.partner_id.street2"/><br/>
                                </t>
                                <t t-if="o.partner_id.city">
                                    <span t-field="o.partner_id.city"/>
                                    <t t-if="o.partner_id.zip"> <span t-field="o.partner_id.zip"/></t>
                                    <br/>
                                </t>
                                <span t-field="o.partner_id.country_id.name"/>
                            </div>
                        </td>
                    </tr>
                </table>

                <!-- Document Title -->
                <div class="document-title">COMMERCIAL INVOICE</div>

                <!-- Ship-To Section -->
                <t t-if="o.partner_shipping_id and o.partner_shipping_id != o.partner_id">
                    <div class="ship-to-section" style="text-align: right;">
                        <div class="ship-to-label">SHIP TO :</div>
                        <span t-field="o.partner_shipping_id.name"/><br/>
                        <t t-if="o.partner_shipping_id.street">
                            <span t-field="o.partner_shipping_id.street"/><br/>
                        </t>
                        <t t-if="o.partner_shipping_id.street2">
                            <span t-field="o.partner_shipping_id.street2"/><br/>
                        </t>
                        <t t-if="o.partner_shipping_id.city">
                            <span t-field="o.partner_shipping_id.city"/>
                            <t t-if="o.partner_shipping_id.zip"> <span t-field="o.partner_shipping_id.zip"/></t>
                            <br/>
                        </t>
                        <span t-field="o.partner_shipping_id.country_id.name"/>
                    </div>
                </t>

                <!-- Shipment & Invoice Info -->
                <div class="info-section">
                    <table style="width: 100%;">
                        <tr>
                            <!-- Shipment Info (Left) -->
                            <td style="width: 50%; vertical-align: top;">
                                <t t-if="o.x_studio_port_of_loading">
                                    <span class="label">Loading : </span><span t-field="o.x_studio_port_of_loading"/><br/>
                                </t>
                                <t t-if="o.x_studio_port_of_destination">
                                    <span class="label">Destination : </span><span t-field="o.x_studio_port_of_destination"/><br/>
                                </t>
                                <t t-if="o.invoice_incoterm_id">
                                    <span class="label">Incoterms : </span><span t-field="o.invoice_incoterm_id.code"/> <span t-field="o.invoice_incoterm_id.name"/><br/>
                                </t>
                                <t t-if="o.x_studio_bl_no">
                                    <span class="label">BL No. : </span><span t-field="o.x_studio_bl_no"/><br/>
                                </t>
                            </td>
                            <!-- Invoice Info (Right) -->
                            <td style="width: 50%; vertical-align: top;">
                                <span class="label">Invoice number : </span>
                                <span t-if="o.x_studio_invoice_number" t-field="o.x_studio_invoice_number"/>
                                <span t-elif="o.name and o.name != '/'" t-field="o.name"/>
                                <span t-else="">Draft</span>
                                <br/>
                                <span class="label">Date : </span>
                                <span t-field="o.invoice_date" t-options='{"format": "MMMM dd, yyyy"}'/>
                                <br/>
                                <span class="label">Yr/order no. : </span><span t-esc="po_numbers_map.get(o.id, '')"/><br/>
                            </td>
                        </tr>
                    </table>
                </div>

                <!-- Invoice Lines Table -->
                <table class="lines-table">
                    <thead>
                        <tr>
                            <th style="width: 8%;">Product<br/>Code</th>
                            <th style="width: 34%;">Description</th>
                            <th style="width: 8%;">Lot No.</th>
                            <th style="width: 8%;">Expiration<br/>Date</th>
                            <th style="width: 7%;" class="text-right">Quantity<br/>(Units)</th>
                            <th style="width: 9%;">PO no.</th>
                            <th style="width: 11%;" class="text-right">Unit Price<br/><span t-esc="o.currency_id.name"/></th>
                            <th style="width: 11%;" class="text-right">Amount<br/><span t-esc="o.currency_id.name"/></th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="o.invoice_line_ids" t-as="line">
                            <tr>
                                <td><span t-if="line.product_id" t-field="line.product_id.default_code"/></td>
                                <td><span t-field="line.name"/></td>
                                <td><span t-if="line.x_studio_lot_number" t-field="line.x_studio_lot_number"/></td>
                                <td><span t-if="line.x_studio_expiration_date" t-field="line.x_studio_expiration_date"/></td>
                                <td class="text-right">
                                    <span t-esc="'{:,.0f}'.format(line.quantity)"/>
                                </td>
                                <td><span t-if="line.x_studio_po_no_ref" t-field="line.x_studio_po_no_ref"/></td>
                                <td class="text-right">
                                    <span t-esc="'{:,.4f}'.format(line.price_unit)"/>
                                </td>
                                <td class="text-right">
                                    <span t-esc="'{:,.2f}'.format(line.price_subtotal)"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <!-- Total -->
                <table style="width: 100%; margin-top: 40px; border-collapse: collapse;">
                    <tr class="total-line">
                        <td style="width: 8%;"></td>
                        <td style="width: 34%;"></td>
                        <td style="width: 8%;"></td>
                        <td style="width: 8%; font-weight: bold; text-align: right; padding-right: 4px;">TOTAL QTY</td>
                        <td style="width: 7%;" class="text-right">
                            <span t-esc="'{:,.0f}'.format(sum(line.quantity for line in o.invoice_line_ids))"/>
                        </td>
                        <td style="width: 9%;"></td>
                        <td style="width: 11%; font-weight: bold;">TOTAL</td>
                        <td style="width: 11%;" class="text-right">
                            <span t-esc="'{:,.2f}'.format(o.amount_total)"/>
                        </td>
                    </tr>
                </table>

                <!-- Origin (from related Sale Order) -->
                <t t-set="related_so" t-value="o.invoice_line_ids.sale_line_ids.order_id[:1]"/>
                <div t-if="related_so and related_so.x_studio_origin" style="margin-top: 15px; font-size: 9pt;">
                    <strong>Origin :</strong> <span t-esc="related_so.x_studio_origin"/>
                </div>

                <!-- Payment Terms & Banking Information -->
                <table style="width: 100%; margin-top: 40px; font-size: 9pt; border-collapse: collapse;">
                    <t t-if="o.invoice_payment_term_id">
                        <tr>
                            <td style="width: 180px; vertical-align: top; padding: 2px 0;"><strong>TERMS OF PAYMENT :</strong></td>
                            <td style="vertical-align: top; padding: 2px 0;">
                                <span t-field="o.invoice_payment_term_id.name" style="text-transform: uppercase;"/>
                            </td>
                        </tr>
                    </t>
                    <tr><td colspan="2" style="padding: 8px 0;"></td></tr>
                    <tr>
                        <td style="vertical-align: top; padding: 2px 0;"><strong>BENEFICIARY :</strong></td>
                        <td style="vertical-align: top; padding: 2px 0;">
                            KLFmed Europe GmbH<br/>
                            <span t-esc="o.currency_id.name"/> Bank Account
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align: top; padding: 2px 0;"><strong>IBAN No. :</strong></td>
                        <td style="vertical-align: top; padding: 2px 0;">
                            <t t-if="o.currency_id.name == 'EUR'">CH69 0027 3273 1390 8560 A</t>
                            <t t-if="o.currency_id.name == 'USD'">CH030027327313908561V</t>
                            <t t-if="o.currency_id.name == 'CHF'">CH460027327313908501J</t>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 2px 0;"></td>
                        <td style="padding: 2px 0;">UBS - Zug branch - Switzerland</td>
                    </tr>
                    <tr>
                        <td style="padding: 2px 0;"></td>
                        <td style="padding: 2px 0;">BIC Swift code : UBSWCHZH80A</td>
                    </tr>
                </table>

                <!-- Wire Transfer Message -->
                <div class="wire-message">
                    <p>PLEASE INSTRUCT YOUR BANK TO USE THE CODE <strong>"OUR"</strong> WHEN MAKING THE WIRE TRANSFER.</p>
                    <p>THIS IN ORDER TO ENSURE THAT WE RECEIVE THE FULL AMOUNT (THE CHARGES FROM OUR BANK WILL BE COVERED BY US). THANK YOU.</p>
                </div>

            </div>
        </t>
    </template>

</odoo>
